# ==========================================
# Primer Production Environment Variables
# Copy this to server/.env.production
# ==========================================

# Core Application Settings
PROJECT_NAME="Primer"
# Must be a long, secure random string! Try: openssl rand -hex 32
SECRET_KEY="super_secret_production_key_change_me"

# CORS Configuration
# Allowed origins for your frontend (e.g. https://primer.yourdomain.com)
ALLOWED_ORIGINS=["http://localhost", "https://primer.yourdomain.com"]

# Database Connections (These map to the docker-compose service names)
DATABASE_URL="postgresql+asyncpg://primer_user:primer_password@db:5432/primer_db"
REDIS_URL="redis://redis:6379/0"
NATS_URL="nats://nats:4222"

# MinIO (S3 Compatible Storage)
MINIO_URL="http://minio:9000"
MINIO_ROOT_USER="minio_admin"
MINIO_ROOT_PASSWORD="minio_secure_password"
MINIO_BUCKET_NAME="primer-bucket"
MINIO_ACCESS_KEY="minio_admin"
MINIO_SECRET_KEY="minio_secure_password"

# GitHub OAuth App (Create a new app for production in GitHub Developer Settings)
GITHUB_CLIENT_ID="your_prod_client_id"
GITHUB_CLIENT_SECRET="your_prod_client_secret"

# PostgreSQL Init Variables (Used by the postgres container)
POSTGRES_USER=primer_user
POSTGRES_PASSWORD=primer_password
POSTGRES_DB=primer_db
